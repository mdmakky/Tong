# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── MongoDB ────────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/dbname

# ─── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://default:password@host:6379

# ─── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key
JWT_REFRESH_SECRET=your-super-secret-refresh-key
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Brevo (transactional email / OTP) ──────────────────────────────────────────
BREVO_API_KEY=your-brevo-api-v3-key
BREVO_FROM_EMAIL=your-verified-sender@domain.com
BREVO_FROM_NAME=Tong Messenger

# ─── Cloudinary ─────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── App ─────────────────────────────────────────────────────────────────────────
# Set this to your Droplet's domain or IP (used for CORS + VITE build arg)
# e.g. http://123.456.789.10  or  https://yourdomain.com
FRONTEND_URL=http://YOUR_DROPLET_IP_OR_DOMAIN

OTP_EXPIRES_MINUTES=10
OTP_LENGTH=6
